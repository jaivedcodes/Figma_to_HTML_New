{
  "name": "figma-to-html",
  "version": "1.0.0",
  "description": "Production-ready Figma to HTML generator — pixel-perfect, responsive, Bootstrap-based output",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "start": "ts-node src/server.ts",
    "build": "tsc",
    "serve": "node dist/server.js",
    "cli": "ts-node src/index.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.6.8",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "express": "^4.19.2",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "prettier": "^3.2.5",
    "sharp": "^0.33.3",
    "svgo": "^3.2.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.11.20",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
